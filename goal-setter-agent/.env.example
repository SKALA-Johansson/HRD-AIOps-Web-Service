# Service
SERVICE_NAME=goal-setter-agent
SERVICE_PORT=10021

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=goal_db
DB_USER=root
DB_PASSWORD=password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=goal-setter-group
KAFKA_CONSUME_TOPIC=onboarding-events
KAFKA_PRODUCE_TOPIC=curriculum-events

# Eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_INSTANCE_HOST=localhost

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
