# Service
SERVICE_NAME=curriculum-designer-agent
SERVICE_PORT=10022

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=curriculum_db
DB_USER=root
DB_PASSWORD=password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=curriculum-designer-group
KAFKA_CONSUME_TOPIC=curriculum-events
KAFKA_PRODUCE_TOPIC=curriculum-events

# Eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_INSTANCE_HOST=localhost

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant (Vector Store)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=curriculum_rag
