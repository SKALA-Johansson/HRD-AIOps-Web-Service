# Service
SERVICE_NAME=ai-tutor-agent
SERVICE_PORT=10024

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tutor_db
DB_USER=root
DB_PASSWORD=password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ai-tutor-group
KAFKA_CONSUME_TOPIC=learning-logs
KAFKA_PRODUCE_TOPIC=learning-logs

# Eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_INSTANCE_HOST=localhost

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant (Vector Store)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=tutor_rag

# Anomaly Detection
ANOMALY_INACTIVITY_HOURS=48       # N시간 이상 비활성 시 이상 감지
ANOMALY_LOW_SCORE_THRESHOLD=40    # 점수가 이 값 이하면 이상 감지
ANOMALY_CONSECUTIVE_FAILS=3       # 연속 실패 횟수
